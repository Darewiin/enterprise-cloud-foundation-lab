# ---- Terraform ----

# Local .terraform directories
**/.terraform/*

# State files — NEVER commit these (they can contain secrets in plaintext)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json

# ...but DO keep the non-secret example template
!*.tfvars.example

# Override files (local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config files
.terraformrc
terraform.rc

# Keep the dependency lock file committed
!.terraform.lock.hcl

# ---- Editor / OS noise ----
.DS_Store
.vscode/
